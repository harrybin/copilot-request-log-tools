{
  "name": "copilot-log-request-tools",
  "displayName": "GH Copilot Request Log Tools",
  "version": "0.1.8",
  "description": "Formatter and syntax highlighting for Copilot request artifacts captured from log files, especially system prompt sections.",
  "icon": "assets/icon.png",
  "publisher": "harrybin",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Formatters",
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:copilot-log-request",
    "onLanguage:plaintext",
    "onLanguage:markdown",
    "onCommand:copilotLogRequest.useForActiveDocument"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilotLogRequest.useForActiveDocument",
        "title": "Use Copilot Log Request Language For Active Document",
        "category": "Copilot Log Request"
      }
    ],
    "languages": [
      {
        "id": "copilot-log-request",
        "aliases": [
          "Copilot Log Request"
        ],
        "extensions": [
          ".copilotlog",
          ".cplog"
        ],
        "filenames": [
          "copilot-system.copilotlog"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "copilot-log-request",
        "scopeName": "text.copilot-log-request",
        "path": "./syntaxes/copilot-request.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Copilot Log Request",
      "properties": {
        "copilotLogRequest.wrapWidth": {
          "type": "number",
          "default": 120,
          "minimum": 40,
          "description": "Column width at which to wrap long prose lines when formatting .copilotlog files."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -p . -w",
    "vscode:prepublish": "npm run compile",
    "test": "npm run compile",
    "package:vscode": "npx @vscode/vsce package --allow-missing-repository --no-dependencies",
    "publish:vscode": "node scripts/vsce-publish.cjs"
  },
  "keywords": [
    "copilot",
    "copilot-log",
    "system-prompt",
    "prompt",
    "formatter",
    "syntax-highlighting"
  ],
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/harrybin/copilot-request-log-tools.git"
  },
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/vscode": "^1.120.0",
    "typescript": "^6.0.3"
  }
}