{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "npm",
            "script": "watch",
            "problemMatcher": "$tsc-watch",
            "isBackground": true,
            "presentation": {
                "reveal": "never"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "type": "npm",
            "script": "compile",
            "problemMatcher": "$tsc",
            "group": "build",
            "presentation": {
                "reveal": "never"
            }
        },
        {
            "label": "Package VSIX",
            "type": "shell",
            "command": "npm run package:vscode",
            "problemMatcher": [],
            "group": "build",
            "detail": "Create a .vsix file for manual upload or local installation",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Install VSIX",
            "type": "shell",
            "command": "code --install-extension (Get-Item *.vsix | Sort-Object LastWriteTime -Descending | Select-Object -First 1).Name --force",
            "problemMatcher": [],
            "dependsOn": "Package VSIX",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Compile and Install",
            "type": "shell",
            "command": "npm run compile && npm run package:vscode && code --install-extension (Get-Item *.vsix | Sort-Object LastWriteTime -Descending | Select-Object -First 1).Name --force",
            "problemMatcher": [
                "$tsc"
            ],
            "group": "build",
            "detail": "Compile TypeScript, package the extension, and install latest VSIX",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Publish Extension",
            "type": "shell",
            "command": "npm run publish:vscode",
            "problemMatcher": [],
            "group": "build",
            "detail": "Publish to VS Code Marketplace (uses MARKETPLACE_TOKEN from .env or VSCE_PAT env var)",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}